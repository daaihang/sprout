    "paywall.footnote": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscriptions renew automatically until canceled in App Store settings. Restore purchases works with the same Apple ID."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクリプションは App Store の設定で解約するまで自動更新されます。購入の復元は同じ Apple ID で利用できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "订阅会自动续费，可在 App Store 账户设置中随时取消。恢复购买适用于同一 Apple ID。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "訂閱會自動續訂，可在 App Store 帳戶設定中隨時取消。恢復購買適用於同一 Apple ID。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les abonnements se renouvellent automatiquement jusqu'à annulation dans les paramètres de l'App Store. La restauration des achats fonctionne avec le même Apple ID."
          }
        },
