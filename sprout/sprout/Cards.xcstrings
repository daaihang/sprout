    "weather.error.auth": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "WeatherKit auth service is unavailable. Confirm WeatherKit is enabled for the App ID and target, and try again on device if needed."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "WeatherKit の認証サービスを利用できません。App ID とターゲットで WeatherKit が有効か確認し、必要に応じて実機で再試行してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "WeatherKit 认证服务不可用。请确认已为 App ID 和 Xcode Target 开启 WeatherKit，必要时在真机再试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "WeatherKit 驗證服務不可用。請確認已為 App ID 和 Xcode Target 啟用 WeatherKit，必要時請在真機上再試。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Le service d'authentification WeatherKit n'est pas disponible. Confirmez que WeatherKit est activé pour l'App ID et la cible, et réessayez sur l'appareil si nécessaire."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "El servicio de autenticación WeatherKit no está disponible. Confirma que WeatherKit está habilitado para el App ID y el objetivo, y vuelve a intentarlo en el dispositivo si es necesario."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Служба аутентификации WeatherKit недоступна. Подтвердите, что WeatherKit включен для App ID и цели, и попробуйте снова на устройстве при необходимости."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "WeatherKit 인증 서비스를 사용할 수 없습니다. App ID 및 대상에 WeatherKit이 활성화되어 있는지 확인하고 필요한 경우 기기에서 다시 시도하세요."
          }
        }
      }
    },
    "weather.error.generic": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Unable to load weather right now. Please try again later."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "天気を取得できません。しばらくしてから再試行してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "天气获取失败，请稍后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "取得天氣失敗，請稍後再試。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de charger la météo pour le moment. Veuillez réessayer plus tard."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "No se puede cargar el clima en este momento. Por favor, inténtalo de nuevo más tarde."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось загрузить погоду. Пожалуйста, попробуйте позже."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 날씨를 불러올 수 없습니다. 나중에 다시 시도해 주세요."
          }
        }
      }
    },
    "weather.error.location": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is unavailable, so weather for your current position cannot be loaded."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "位置情報を利用できないため、現在地の天気を取得できません。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "定位不可用，无法获取当前位置天气。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "定位不可用，無法取得目前位置的天氣。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La localisation n'est pas disponible, donc la météo de votre position actuelle ne peut pas être chargée."
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "La ubicación no está disponible, por lo que no se puede cargar el clima de tu posición actual."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Местоположение недоступно, поэтому погода для вашей текущей позиции не может быть загружена."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위치를 사용할 수 없어서 현재 위치의 날씨를 불러올 수 없습니다."
          }
        }
      }
    },
