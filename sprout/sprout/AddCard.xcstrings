    "add_card.weather.error.permission": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Allow location access to fill in current weather automatically"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在地の天気を自動入力するには位置情報を許可してください"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请允许定位后自动填充当前位置天气"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請允許定位後自動填入目前位置的天氣"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Autorisez l'accès à la localisation pour remplir automatiquement la météo actuelle"
          }
        },
        "es-419": {
          "stringUnit": {
            "state": "translated",
            "value": "Permite el acceso a la ubicación para completar automáticamente el clima actual"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Разрешите доступ к местоположению для автоматического заполнения текущей погоды"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "현재 날씨를 자동으로 입력하려면 위치 접근을 허용하세요"
          }
        }
      }
    },
    "add_card.weather.error.unavailable": {
      "extractionState": "stale",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Current location is unavailable right now. Try again shortly."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "現在地を取得できません。しばらくしてから再試行してください。"
          }
        },
        "zh-Hans": {
