    "NSAppleMusicUsageDescription" : {
      "comment" : "Permission prompt for Apple Music library access.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use your music library to show the song that is playing."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "再生中の曲を表示するために、ミュージックライブラリへのアクセスを使用します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们需要访问你的音乐资料库，以显示当前正在播放的歌曲。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我們需要存取你的音樂資料庫，以顯示目前正在播放的歌曲。"
          }
        }
      }
    },
    "NSFaceIDUsageDescription" : {
      "comment" : "Permission prompt for Face ID authentication.",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We use Face ID to verify your identity securely."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "安全に本人確認を行うために Face ID を使用します。"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我们会使用 Face ID 安全地验证你的身份。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "我們會使用 Face ID 安全地驗證你的身分。"
          }
        }
      }
    },
