APP_ENV=development
PORT=8080
JWT_SECRET=dev-secret-change-me
DEV_AUTH_ENABLED=true
DEV_AUTH_USER_ID=dev-user

AI_MODE=live
AI_PROVIDER=openai_compatible
AI_MODEL=deepseek-chat
AI_BASE_URL=https://api.deepseek.com
AI_API_KEY=fill_your_deepseek_api_key_here

JWT_TTL=1h
HTTP_TIMEOUT=60s
AI_MAX_RETRIES=2
AI_RETRY_BACKOFF=300ms

# APNs remote push delivery. Keep disabled for local development unless
# you have an Apple Push Notifications auth key and a real bundle topic.
APNS_ENABLED=false
APNS_ENVIRONMENT=sandbox
APNS_TOPIC=com.speculolabs.mory
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_AUTH_KEY_PATH=
APNS_AUTH_KEY=
APNS_BASE_URL=

# Server-side queued push delivery worker.
PUSH_DELIVERY_WORKER_ENABLED=true
PUSH_DELIVERY_INTERVAL=30s
PUSH_DELIVERY_BATCH_SIZE=32
PUSH_DELIVERY_MAX_ATTEMPTS=5
PUSH_DELIVERY_RETRY_BACKOFF=2m
PUSH_DELIVERY_ALERT_FAILURE_THRESHOLD=3
